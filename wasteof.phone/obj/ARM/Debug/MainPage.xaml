<Page
    x:Class="wasteof.phone.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:wasteof.phone"
    xmlns:models="using:wasteof.phone.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid x:Name="LayoutRoot">
        <Pivot x:ConnectionId='1' x:Name="MainPivot" Title="WASTEOF.PHONE"                                              >
            
            <!-- FEED TAB -->
            <PivotItem Header="feed">
                <Grid>
                    <ProgressBar x:Name="FeedProgressBar" VerticalAlignment="Top" IsIndeterminate="True" Visibility="Collapsed"/>
                    <ListView x:ConnectionId='7' x:Name="FeedListView" IsItemClickEnabled="True"                                    HorizontalContentAlignment="Stretch">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="19,8,19,16" HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Profile Picture -->
                                    <Border x:ConnectionId='8' Width="40" Height="40" CornerRadius="20" VerticalAlignment="Top" Margin="0,0,12,0" Background="{ThemeResource PhoneBorderBrush}"                         >
                                        <Image Source="{Binding Poster.ProfilePictureUrl}" Width="40" Height="40" Stretch="UniformToFill"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" HorizontalAlignment="Stretch">
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Clickable username -->
                                            <TextBlock x:ConnectionId='9' Text="{Binding Poster.Name}" FontWeight="Bold" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{StaticResource PhoneAccentBrush}"                         />
                                            <TextBlock Grid.Column="1" Text="{Binding FormattedTime}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{StaticResource PhoneMutedBrush}"/>
                                        </Grid>
                                        
                                        <TextBlock Text="{Binding CleanContent}" TextWrapping="Wrap" MaxLines="3" TextTrimming="WordEllipsis" Style="{ThemeResource BodyTextBlockStyle}"/>
                                        
                                        <!-- Repost indicator -->
                                        <Border BorderBrush="{StaticResource PhoneAccentBrush}" BorderThickness="2,0,0,0" Padding="6,0,0,0" Margin="0,4,0,4" Visibility="{Binding Repost, Converter={StaticResource NullToVisibilityConverter}, FallbackValue=Collapsed}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Repost.Poster.Name}" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                                <TextBlock Text="{Binding Repost.CleanContent}" TextWrapping="Wrap" MaxLines="2" TextTrimming="WordEllipsis" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Loves & Comments counts -->
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="♥" Foreground="{Binding LoveHeartColor}" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding LovesCount}" Margin="0,0,16,0" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                            <TextBlock Text="💬" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding CommentsCount}" Margin="0,0,16,0" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                            <TextBlock Text="🔁" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding RepostsCount}" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </PivotItem>

            <!-- EXPLORE TAB -->
            <PivotItem Header="explore">
                <Grid>
                    <ProgressBar x:Name="ExploreProgressBar" VerticalAlignment="Top" IsIndeterminate="True" Visibility="Collapsed"/>
                    <ListView x:ConnectionId='4' x:Name="ExploreListView" IsItemClickEnabled="True"                                    HorizontalContentAlignment="Stretch">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="19,8,19,16" HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Profile Picture -->
                                    <Border x:ConnectionId='5' Width="40" Height="40" CornerRadius="20" VerticalAlignment="Top" Margin="0,0,12,0" Background="{ThemeResource PhoneBorderBrush}"                         >
                                        <Image Source="{Binding Poster.ProfilePictureUrl}" Width="40" Height="40" Stretch="UniformToFill"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" HorizontalAlignment="Stretch">
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:ConnectionId='6' Text="{Binding Poster.Name}" FontWeight="Bold" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{StaticResource PhoneAccentBrush}"                         />
                                            <TextBlock Grid.Column="1" Text="{Binding FormattedTime}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{StaticResource PhoneMutedBrush}"/>
                                        </Grid>
                                        
                                        <TextBlock Text="{Binding CleanContent}" TextWrapping="Wrap" MaxLines="3" TextTrimming="WordEllipsis" Style="{ThemeResource BodyTextBlockStyle}"/>
                                        
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="♥" Foreground="{Binding LoveHeartColor}" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding LovesCount}" Margin="0,0,16,0" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                            <TextBlock Text="💬" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding CommentsCount}" Margin="0,0,16,0" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                            <TextBlock Text="🔁" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding RepostsCount}" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </PivotItem>

            <!-- NOTIFICATIONS TAB -->
            <PivotItem Header="notifications">
                <Grid>
                    <ProgressBar x:Name="NotificationsProgressBar" VerticalAlignment="Top" IsIndeterminate="True" Visibility="Collapsed"/>
                    <ListView x:ConnectionId='3' x:Name="NotificationsListView" IsItemClickEnabled="True"                                             HorizontalContentAlignment="Stretch">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="19,8,19,16" HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Actor Profile Picture -->
                                    <Border Width="40" Height="40" CornerRadius="20" VerticalAlignment="Top" Margin="0,0,12,0" Background="{ThemeResource PhoneBorderBrush}">
                                        <Image Source="{Binding Data.Actor.ProfilePictureUrl}" Width="40" Height="40" Stretch="UniformToFill"/>
                                    </Border>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding NotificationText}" TextWrapping="Wrap" FontWeight="SemiBold" Style="{ThemeResource BodyTextBlockStyle}"/>
                                        <TextBlock Text="{Binding Data.Content}" Margin="0,2,0,0" TextWrapping="Wrap" MaxLines="2" TextTrimming="WordEllipsis" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{StaticResource PhoneMutedBrush}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="2" Text="{Binding FormattedTime}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{StaticResource PhoneMutedBrush}" VerticalAlignment="Top" Margin="8,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </PivotItem>

            <!-- ACCOUNT TAB -->
            <PivotItem Header="account">
                <Grid>
                    <ProgressBar x:Name="AccountProgressBar" VerticalAlignment="Top" IsIndeterminate="True" Visibility="Collapsed"/>
                    <ListView x:ConnectionId='2' x:Name="MyPostsListView" IsItemClickEnabled="True"                                    HorizontalContentAlignment="Stretch">
                        <ListView.Header>
                            <!-- Personal Profile Info -->
                            <Border Margin="19,8,19,16" BorderBrush="{ThemeResource PhoneBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,16">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Profile Picture -->
                                        <Border Width="64" Height="64" CornerRadius="32" VerticalAlignment="Center" Margin="0,0,12,0" Background="{ThemeResource PhoneBorderBrush}">
                                            <Image x:Name="AccountProfilePictureImage" Width="64" Height="64" Stretch="UniformToFill"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock x:Name="AccountDisplayName" Text="Display Name" FontWeight="Bold" Style="{ThemeResource SubheaderTextBlockStyle}"/>
                                            <TextBlock x:Name="AccountBio" Text="Bio text goes here..." TextWrapping="Wrap" Margin="0,4,0,12" Style="{ThemeResource BodyTextBlockStyle}"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Stats Row -->
                                    <Grid Margin="0,8,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                            <TextBlock x:Name="MyPostsCount" Text="0" FontWeight="Bold" HorizontalAlignment="Center" Style="{ThemeResource SubheaderTextBlockStyle}"/>
                                            <TextBlock Text="posts" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{StaticResource PhoneMutedBrush}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                            <TextBlock x:Name="MyFollowersCount" Text="0" FontWeight="Bold" HorizontalAlignment="Center" Style="{ThemeResource SubheaderTextBlockStyle}"/>
                                            <TextBlock Text="followers" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{StaticResource PhoneMutedBrush}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                            <TextBlock x:Name="MyFollowingCount" Text="0" FontWeight="Bold" HorizontalAlignment="Center" Style="{ThemeResource SubheaderTextBlockStyle}"/>
                                            <TextBlock Text="following" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{StaticResource PhoneMutedBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </ListView.Header>

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="19,8,19,16" HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Profile Picture -->
                                    <Border Width="40" Height="40" CornerRadius="20" VerticalAlignment="Top" Margin="0,0,12,0" Background="{ThemeResource PhoneBorderBrush}">
                                        <Image Source="{Binding Poster.ProfilePictureUrl}" Width="40" Height="40" Stretch="UniformToFill"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" HorizontalAlignment="Stretch">
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Poster.Name}" FontWeight="Bold" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{StaticResource PhoneAccentBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding FormattedTime}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{StaticResource PhoneMutedBrush}"/>
                                        </Grid>
                                        <TextBlock Text="{Binding CleanContent}" TextWrapping="Wrap" MaxLines="3" TextTrimming="WordEllipsis" Style="{ThemeResource BodyTextBlockStyle}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="♥" Foreground="{Binding LoveHeartColor}" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding LovesCount}" Margin="0,0,16,0" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                            <TextBlock Text="💬" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding CommentsCount}" Margin="0,0,16,0" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                            <TextBlock Text="🔁" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding RepostsCount}" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </PivotItem>
        </Pivot>
    </Grid>

    <Page.BottomAppBar>
        <CommandBar>
            <AppBarButton x:ConnectionId='10' x:Name="ComposeButton" Icon="Add" Label="compose"                             />
            <AppBarButton x:ConnectionId='11' x:Name="RefreshButton" Icon="Refresh" Label="refresh"                             />
            <CommandBar.SecondaryCommands>
                <AppBarButton x:ConnectionId='12' x:Name="LogoutButton" Label="log out"                            />
            </CommandBar.SecondaryCommands>
        </CommandBar>
    </Page.BottomAppBar>
</Page>

