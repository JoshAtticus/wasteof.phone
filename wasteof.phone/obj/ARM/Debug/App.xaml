<Application
    x:Class="wasteof.phone.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:wasteof.phone">

    <Application.Resources>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        
        <!-- Custom Color Brushes for premium wasteof styling -->
        <SolidColorBrush x:Key="PhoneAccentBrush" Color="#6366F1" />
        <SolidColorBrush x:Key="PhoneMutedBrush" Color="#888888" />
        <SolidColorBrush x:Key="PhoneBorderBrush" Color="#333333" />
        <SolidColorBrush x:Key="OnlineColorBrush" Color="#10B981" />
        
        <!-- Button Simple style for Love, Repost, Comment buttons -->
        <Style x:Key="ButtonSimpleStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,4,4,4"/>
            <Setter Property="Foreground" Value="{StaticResource PhoneAccentBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="MinWidth" Value="60"/>
        </Style>

        <!-- Post list view item style -->
        <Style x:Key="MessageTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextBlockStyle}">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="LineHeight" Value="24" />
        </Style>

        <!-- Global Caption Style (replaces Windows 10 UWP system style) -->
        <Style x:Key="CaptionTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextBlockStyle}">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource PhoneMutedBrush}"/>
        </Style>

        <!-- Global ListViewItem Style to stretch items horizontally -->
        <Style TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
    </Application.Resources>
</Application>

