<Page
    x:Class="wasteof.phone.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:wasteof.phone"
    xmlns:models="using:wasteof.phone.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid x:Name="LayoutRoot">
        <Pivot x:Name="MainPivot" Title="WASTEOF.PHONE" SelectionChanged="MainPivot_SelectionChanged">
            
            <!-- FEED TAB -->
            <PivotItem Header="feed">
                <Grid>
                    <ProgressBar x:Name="FeedProgressBar" VerticalAlignment="Top" IsIndeterminate="True" Visibility="Collapsed"/>
                    <ListView x:Name="FeedListView" IsItemClickEnabled="True" ItemClick="PostListView_ItemClick" HorizontalContentAlignment="Stretch">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="19,8,19,16" HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Profile Picture -->
                                    <Border Width="40" Height="40" VerticalAlignment="Top" Margin="0,0,12,0" Background="{ThemeResource PhoneBorderBrush}" Tapped="Username_Tapped">
                                        <Image Source="{Binding Poster.ProfilePictureUrl}" Width="40" Height="40" Stretch="UniformToFill"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" HorizontalAlignment="Stretch">
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Clickable username -->
                                            <TextBlock Text="{Binding Poster.Name}" FontWeight="Bold" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{StaticResource PhoneAccentBrush}" Tapped="Username_Tapped"/>
                                            <TextBlock Grid.Column="1" Text="{Binding FormattedTime}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{StaticResource PhoneMutedBrush}"/>
                                        </Grid>
                                        
                                        <TextBlock Text="{Binding CleanContent}" TextWrapping="Wrap" MaxLines="3" TextTrimming="WordEllipsis" Style="{ThemeResource BodyTextBlockStyle}"/>
                                        
                                        <!-- Repost indicator -->
                                        <Border BorderBrush="{StaticResource PhoneAccentBrush}" BorderThickness="2,0,0,0" Padding="6,0,0,0" Margin="0,4,0,4" Visibility="{Binding Repost, Converter={StaticResource NullToVisibilityConverter}, FallbackValue=Collapsed}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Repost.Poster.Name}" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                                <TextBlock Text="{Binding Repost.CleanContent}" TextWrapping="Wrap" MaxLines="2" TextTrimming="WordEllipsis" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Stat Buttons Row -->
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <!-- Love Button -->
                                            <Button Click="LoveButton_Click" Width="80" Margin="0,0,12,0" Padding="0" MinHeight="36" Style="{StaticResource ButtonSimpleStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="M 12,5 C 10,3 6,3 4,5 C 2,7 2,11 4,13 L 12,21 L 20,13 C 22,11 22,7 20,5 C 18,3 14,3 12,5 Z" Stroke="{Binding LoveHeartStroke}" StrokeThickness="2" Fill="{Binding LoveHeartFill}" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding LovesCount}" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>

                                            <!-- Comment Button -->
                                            <Button Click="CommentButton_Click" Width="80" Margin="0,0,12,0" Padding="0" MinHeight="36" Style="{StaticResource ButtonSimpleStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="M 2,4 L 22,4 L 22,16 L 8,16 L 3,21 L 3,16 L 2,16 Z" Stroke="{ThemeResource PhoneMutedBrush}" StrokeThickness="2" Fill="Transparent" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding CommentsCount}" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>

                                            <!-- Repost Button -->
                                            <Button Click="RepostButton_Click" Width="80" Padding="0" MinHeight="36" Style="{StaticResource ButtonSimpleStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="M 4,12 L 4,7 C 4,5 5,4 7,4 L 17,4 M 13,1 L 18,4 L 13,7 M 16,8 L 16,13 C 16,15 15,16 13,16 L 3,16 M 7,13 L 2,16 L 7,19" Stroke="{ThemeResource PhoneMutedBrush}" StrokeThickness="2" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0">
                                                        <Path.RenderTransform>
                                                            <RotateTransform Angle="-30" CenterX="9" CenterY="9"/>
                                                        </Path.RenderTransform>
                                                    </Path>
                                                    <TextBlock Text="{Binding RepostsCount}" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <ListView.Footer>
                            <Button x:Name="LoadMoreFeedButton" Content="load more..." Click="LoadMoreFeedButton_Click" HorizontalAlignment="Center" Margin="0,12,0,12" Style="{ThemeResource ButtonSimpleStyle}" Visibility="Collapsed"/>
                        </ListView.Footer>
                    </ListView>
                </Grid>
            </PivotItem>

            <!-- EXPLORE TAB -->
            <PivotItem Header="explore">
                <Grid>
                    <ProgressBar x:Name="ExploreProgressBar" VerticalAlignment="Top" IsIndeterminate="True" Visibility="Collapsed"/>
                    <ListView x:Name="ExploreListView" IsItemClickEnabled="True" ItemClick="PostListView_ItemClick" HorizontalContentAlignment="Stretch">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="19,8,19,16" HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Profile Picture -->
                                    <Border Width="40" Height="40" VerticalAlignment="Top" Margin="0,0,12,0" Background="{ThemeResource PhoneBorderBrush}" Tapped="Username_Tapped">
                                        <Image Source="{Binding Poster.ProfilePictureUrl}" Width="40" Height="40" Stretch="UniformToFill"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" HorizontalAlignment="Stretch">
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Poster.Name}" FontWeight="Bold" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{StaticResource PhoneAccentBrush}" Tapped="Username_Tapped"/>
                                            <TextBlock Grid.Column="1" Text="{Binding FormattedTime}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{StaticResource PhoneMutedBrush}"/>
                                        </Grid>
                                        
                                        <TextBlock Text="{Binding CleanContent}" TextWrapping="Wrap" MaxLines="3" TextTrimming="WordEllipsis" Style="{ThemeResource BodyTextBlockStyle}"/>
                                        
                                        <!-- Stat Buttons Row -->
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <!-- Love Button -->
                                            <Button Click="LoveButton_Click" Width="80" Margin="0,0,12,0" Padding="0" MinHeight="36" Style="{StaticResource ButtonSimpleStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="M 12,5 C 10,3 6,3 4,5 C 2,7 2,11 4,13 L 12,21 L 20,13 C 22,11 22,7 20,5 C 18,3 14,3 12,5 Z" Stroke="{Binding LoveHeartStroke}" StrokeThickness="2" Fill="{Binding LoveHeartFill}" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding LovesCount}" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>

                                            <!-- Comment Button -->
                                            <Button Click="CommentButton_Click" Width="80" Margin="0,0,12,0" Padding="0" MinHeight="36" Style="{StaticResource ButtonSimpleStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="M 2,4 L 22,4 L 22,16 L 8,16 L 3,21 L 3,16 L 2,16 Z" Stroke="{ThemeResource PhoneMutedBrush}" StrokeThickness="2" Fill="Transparent" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding CommentsCount}" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>

                                            <!-- Repost Button -->
                                            <Button Click="RepostButton_Click" Width="80" Padding="0" MinHeight="36" Style="{StaticResource ButtonSimpleStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="M 4,12 L 4,7 C 4,5 5,4 7,4 L 17,4 M 13,1 L 18,4 L 13,7 M 16,8 L 16,13 C 16,15 15,16 13,16 L 3,16 M 7,13 L 2,16 L 7,19" Stroke="{ThemeResource PhoneMutedBrush}" StrokeThickness="2" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0">
                                                        <Path.RenderTransform>
                                                            <RotateTransform Angle="-30" CenterX="9" CenterY="9"/>
                                                        </Path.RenderTransform>
                                                    </Path>
                                                    <TextBlock Text="{Binding RepostsCount}" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <ListView.Footer>
                            <Button x:Name="LoadMoreExploreButton" Content="load more..." Click="LoadMoreExploreButton_Click" HorizontalAlignment="Center" Margin="0,12,0,12" Style="{ThemeResource ButtonSimpleStyle}" Visibility="Collapsed"/>
                        </ListView.Footer>
                    </ListView>
                </Grid>
            </PivotItem>

            <!-- ACCOUNT TAB -->
            <PivotItem Header="account">
                <Grid>
                    <ProgressBar x:Name="AccountProgressBar" VerticalAlignment="Top" IsIndeterminate="True" Visibility="Collapsed"/>
                    <ListView x:Name="MyPostsListView" IsItemClickEnabled="True" ItemClick="PostListView_ItemClick" HorizontalContentAlignment="Stretch">
                        <ListView.Header>
                            <!-- Personal Profile Info -->
                            <Border Margin="19,8,19,16" BorderBrush="{ThemeResource PhoneBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,16">
                                <StackPanel>
                                    <!-- Banner Image -->
                                    <Grid Height="120" Margin="0,0,0,12" Background="{ThemeResource PhoneBorderBrush}">
                                        <Image x:Name="AccountBannerImage" Stretch="UniformToFill" Height="120"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Profile Picture -->
                                        <Border Width="64" Height="64" VerticalAlignment="Center" Margin="0,0,12,0" Background="{ThemeResource PhoneBorderBrush}">
                                            <Image x:Name="AccountProfilePictureImage" Width="64" Height="64" Stretch="UniformToFill"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock x:Name="AccountDisplayName" Text="Display Name" FontWeight="Bold" Style="{ThemeResource SubheaderTextBlockStyle}"/>
                                            <TextBlock x:Name="AccountBio" Text="Bio text goes here..." TextWrapping="Wrap" Margin="0,4,0,12" Style="{ThemeResource BodyTextBlockStyle}"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Stats Row -->
                                    <Grid Margin="0,8,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                            <TextBlock x:Name="MyPostsCount" Text="0" FontWeight="Bold" HorizontalAlignment="Center" Style="{ThemeResource SubheaderTextBlockStyle}"/>
                                            <TextBlock Text="posts" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{StaticResource PhoneMutedBrush}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                            <TextBlock x:Name="MyFollowersCount" Text="0" FontWeight="Bold" HorizontalAlignment="Center" Style="{ThemeResource SubheaderTextBlockStyle}"/>
                                            <TextBlock Text="followers" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{StaticResource PhoneMutedBrush}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                            <TextBlock x:Name="MyFollowingCount" Text="0" FontWeight="Bold" HorizontalAlignment="Center" Style="{ThemeResource SubheaderTextBlockStyle}"/>
                                            <TextBlock Text="following" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{StaticResource PhoneMutedBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </ListView.Header>

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="19,8,19,16" HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Profile Picture -->
                                    <Border Width="40" Height="40" VerticalAlignment="Top" Margin="0,0,12,0" Background="{ThemeResource PhoneBorderBrush}">
                                        <Image Source="{Binding Poster.ProfilePictureUrl}" Width="40" Height="40" Stretch="UniformToFill"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" HorizontalAlignment="Stretch">
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Poster.Name}" FontWeight="Bold" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{StaticResource PhoneAccentBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding FormattedTime}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{StaticResource PhoneMutedBrush}"/>
                                        </Grid>
                                        <TextBlock Text="{Binding CleanContent}" TextWrapping="Wrap" MaxLines="3" TextTrimming="WordEllipsis" Style="{ThemeResource BodyTextBlockStyle}"/>
                                        
                                        <!-- Stat Buttons Row -->
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <!-- Love Button -->
                                            <Button Click="LoveButton_Click" Width="80" Margin="0,0,12,0" Padding="0" MinHeight="36" Style="{StaticResource ButtonSimpleStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="M 12,5 C 10,3 6,3 4,5 C 2,7 2,11 4,13 L 12,21 L 20,13 C 22,11 22,7 20,5 C 18,3 14,3 12,5 Z" Stroke="{Binding LoveHeartStroke}" StrokeThickness="2" Fill="{Binding LoveHeartFill}" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding LovesCount}" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>

                                            <!-- Comment Button -->
                                            <Button Click="CommentButton_Click" Width="80" Margin="0,0,12,0" Padding="0" MinHeight="36" Style="{StaticResource ButtonSimpleStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="M 2,4 L 22,4 L 22,16 L 8,16 L 3,21 L 3,16 L 2,16 Z" Stroke="{ThemeResource PhoneMutedBrush}" StrokeThickness="2" Fill="Transparent" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding CommentsCount}" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>

                                            <!-- Repost Button -->
                                            <Button Click="RepostButton_Click" Width="80" Padding="0" MinHeight="36" Style="{StaticResource ButtonSimpleStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="M 4,12 L 4,7 C 4,5 5,4 7,4 L 17,4 M 13,1 L 18,4 L 13,7 M 16,8 L 16,13 C 16,15 15,16 13,16 L 3,16 M 7,13 L 2,16 L 7,19" Stroke="{ThemeResource PhoneMutedBrush}" StrokeThickness="2" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0">
                                                        <Path.RenderTransform>
                                                            <RotateTransform Angle="-30" CenterX="9" CenterY="9"/>
                                                        </Path.RenderTransform>
                                                    </Path>
                                                    <TextBlock Text="{Binding RepostsCount}" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <ListView.Footer>
                            <Button x:Name="LoadMoreMyPostsButton" Content="load more..." Click="LoadMoreMyPostsButton_Click" HorizontalAlignment="Center" Margin="0,12,0,12" Style="{ThemeResource ButtonSimpleStyle}" Visibility="Collapsed"/>
                        </ListView.Footer>
                    </ListView>
                </Grid>
            </PivotItem>
        </Pivot>
    </Grid>

    <Page.BottomAppBar>
        <CommandBar>
            <AppBarButton x:Name="ComposeButton" Icon="Add" Label="compose" Click="ComposeButton_Click" />
            <AppBarButton x:Name="NotificationsButton" Icon="Message" Label="messages" Click="NotificationsButton_Click"/>
            <AppBarButton x:Name="RefreshButton" Icon="Refresh" Label="refresh" Click="RefreshButton_Click" />
            <CommandBar.SecondaryCommands>
                <AppBarButton x:Name="LogoutButton" Label="log out" Click="LogoutButton_Click" />
            </CommandBar.SecondaryCommands>
        </CommandBar>
    </Page.BottomAppBar>
</Page>
