<Page
    x:Class="wasteof.phone.ComposePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:wasteof.phone"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid x:Name="LayoutRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="19,19,0,12">
            <TextBlock x:Name="PageHeaderTitle" Text="compose" Margin="0,-6.5,0,0" Style="{ThemeResource HeaderTextBlockStyle}"/>
        </StackPanel>

        <Grid Grid.Row="1" x:Name="ContentPanel" Margin="19,0,19,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="RepostIndicator" Text="reposting..." Foreground="{ThemeResource PhoneAccentBrush}" Margin="0,0,0,8" Visibility="Collapsed" Style="{ThemeResource BodyTextBlockStyle}"/>
            
            <TextBox x:Name="PostContentTextBox" Grid.Row="1" 
                     PlaceholderText="what's on your mind?" 
                     AcceptsReturn="True" 
                     TextWrapping="Wrap" 
                     MaxLength="5000"
                     VerticalAlignment="Stretch"
                     HorizontalAlignment="Stretch"
                     TextChanged="PostContentTextBox_TextChanged"/>

            <Grid Grid.Row="2" Height="110" Margin="0,8,0,8">
                <GridView x:Name="ImagesGridView"
                          SelectionMode="None"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Disabled"
                          ScrollViewer.HorizontalScrollMode="Enabled"
                          ScrollViewer.VerticalScrollMode="Disabled">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="100" Height="100" Margin="0,0,8,0" Background="{ThemeResource PhoneBorderBrush}"
                                  ManipulationMode="TranslateX"
                                  ManipulationDelta="PreviewGrid_ManipulationDelta"
                                  ManipulationCompleted="PreviewGrid_ManipulationCompleted"
                                  Tapped="PreviewGrid_Tapped">
                                <Image Source="{Binding}" Stretch="UniformToFill" Width="100" Height="100"/>
                            </Grid>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

                <!-- Loading Spinner for Uploads -->
                <ProgressRing x:Name="UploadProgressRing" 
                              Width="40" 
                              Height="40" 
                              IsActive="False" 
                              HorizontalAlignment="Center" 
                              VerticalAlignment="Center"
                              Foreground="{ThemeResource PhoneAccentBrush}"/>
            </Grid>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,12">
                <TextBlock x:Name="CharCountTextBlock" Text="0 / 5000" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource PhoneMutedBrush}"/>
            </StackPanel>
        </Grid>

        <!-- Large Image Preview Overlay -->
        <Grid x:Name="ImagePreviewModal" Grid.RowSpan="2" Background="#F2000000" Visibility="Collapsed" Tapped="ImagePreviewModal_BackdropTapped">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Image x:Name="LargePreviewImage" Stretch="Uniform" Margin="24,24,24,12" VerticalAlignment="Center" HorizontalAlignment="Center"/>

            <StackPanel Grid.Row="1" Margin="24,0,24,24">
                <Button Content="delete image" 
                        Click="DeletePreviewedImageButton_Click" 
                        Foreground="Red" 
                        HorizontalAlignment="Stretch" 
                        Margin="0,0,0,12"/>
                <Button Content="close" 
                        Click="ClosePreviewButton_Click" 
                        HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Grid>
    </Grid>

    <Page.BottomAppBar>
        <CommandBar>
            <AppBarButton x:Name="PostAppBarButton" Icon="Accept" Label="post" Click="PostAppBarButton_Click"/>
            <AppBarButton x:Name="AddImageAppBarButton" Icon="Camera" Label="add image" Click="AddImageAppBarButton_Click"/>
            <AppBarButton x:Name="CancelAppBarButton" Icon="Cancel" Label="cancel" Click="CancelAppBarButton_Click"/>
        </CommandBar>
    </Page.BottomAppBar>
</Page>
